    {
      "parameters": {
        "jsCode": "const num = v => {\n  const n = parseFloat(String(v ?? \"\").replace(\",\", \".\"));\n  return Number.isFinite(n) ? n : NaN;\n};\n\nconst rows = $input.all().map(i => i.json);\n\nconst deals = rows\n  .map(r => {\n    const regular = num(r[\"Redovna cena\"]);\n    const sale = num(r[\"Snižena cena\"]);\n\n    if (!(regular > 0) || !(sale > 0) || sale >= regular) return null;\n\n    const pct = ((regular - sale) / regular) * 100;\n\n    return {\n      name: r[\"Naziv proizvoda\"] ?? \"\",\n      brand: r[\"Robna marka\"] ?? \"\",\n      regular,\n      sale,\n      pct,\n      start: r[\"Datum početka sniženja\"] ?? null,\n      end: r[\"Datum kraja sniženja\"] ?? null,\n    };\n  })\n  .filter(Boolean)\n  .sort((a, b) => b.pct - a.pct);\n\nconst top10 = deals.slice(0, 10);\n\nconst output = top10.length\n  ? \"Top 10 discounts:\\n\\n\" +\n    top10\n      .map((d, i) => {\n        const brand = d.brand && d.brand !== \"RM NIJE DEFINISANA\" ? ` | ${d.brand}` : \"\";\n        return `${d.name}${brand} - ${d.sale.toFixed(2)} RSD (was ${d.regular.toFixed(2)}) | -${d.pct.toFixed(1)}%\\n`;\n      })\n      .join(\"\\n\")\n  : \"No discounted items found.\";\n\nreturn [{ json: { output } }];\n"
      },
