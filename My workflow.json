    {
      "parameters": {
        "jsCode": "const num = v => parseFloat(String(v ?? \"\").replace(\",\", \".\"));\n\nconst rows = $input.all().map(i => i.json);\n\nconst agg = {};\n\nfor (const r of rows) {\n  const cat = String(r[\"NAZIV KATEGORIJE\"] ?? \"NEPOZNATO\").trim();\n  const price = num(r[\"Redovna cena\"]);\n  if (!Number.isFinite(price)) continue;\n\n  if (!agg[cat]) agg[cat] = { sum: 0, count: 0 };\n  agg[cat].sum += price;\n  agg[cat].count += 1;\n}\n\nconst list = Object.entries(agg)\n  .map(([cat, a]) => ({ cat, avg: a.sum / a.count, count: a.count }))\n  .sort((a, b) => b.avg - a.avg);\n\nconst output = list.length\n  ? \"Average regular price by category:\\n\\n\" +\n    list\n      .map(x => `${x.cat}: ${x.avg.toFixed(2)} RSD (items: ${x.count})\\n`)\n      .join(\"\\n\")\n  : \"No valid prices found in the file.\";\n\nreturn [{ json: { output } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
